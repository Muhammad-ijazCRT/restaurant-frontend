# Copy to .env.local for local development (never affects Vercel production).
# Vercel uses its own env vars from the dashboard — not this file.

# --- Local only (.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:5000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Production only (set in Vercel dashboard) ---
# NEXT_PUBLIC_API_URL=https://web-production-35f13.up.railway.app
# NEXT_PUBLIC_APP_URL=https://restaurant-frontend-ten-livid.vercel.app

NEXT_PUBLIC_ENABLE_CRYPTO=true
NEXT_PUBLIC_ENABLE_LOCAL_PAYMENT_SIMULATION=true
